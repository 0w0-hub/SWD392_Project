# Broker (service registry) — cổng riêng
# Spring Boot đọc biến môi trường SERVER_PORT (relaxed binding -> server.port).
# Port cũng được cấu hình sẵn ở src/main/resources/application.properties.
# Cách nạp file này (PowerShell):  Get-Content .env | ForEach-Object { if ($_ -notmatch '^#' -and $_){ $p=$_.Split('=',2); [Environment]::SetEnvironmentVariable($p[0],$p[1]) } }
SERVER_PORT=8080
