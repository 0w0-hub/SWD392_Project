# Coordinator (Layer 2 + 3) — cổng riêng của service này
PORT=3010

# Broker (service registry) để tự đăng ký + discover
BROKER_URL=http://localhost:8080

# URL fallback tới từng service (dùng khi Broker chưa có đăng ký của service đó)
CATALOG_URL=http://localhost:3000
DELIVERY_URL=http://localhost:3001
INVENTORY_URL=http://localhost:3004
ACCOUNT_URL=http://localhost:8081
CREDITCARD_URL=http://localhost:3006
EMAIL_URL=http://localhost:3005
