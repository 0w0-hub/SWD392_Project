# CustomerAccountService (Layer 1) — cổng riêng
# Spring Boot đọc biến môi trường SERVER_PORT (relaxed binding -> server.port).
# Port cũng được cấu hình sẵn ở src/main/resources/application.properties.
SERVER_PORT=8081

# Broker (service registry) — service này tự đăng ký lúc khởi động
BROKER_BASE_URL=http://localhost:8080
